{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "运行扩展（热更新）",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "dev: watch",
      "env": {
        "SQLITE_TOOL_WEBVIEW_DEV_SERVER": "http://localhost:19753"
      }
    },
    {
      "name": "运行扩展",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: build"
    }
  ]
}
