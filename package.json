{
  "name": "sqlite-tool",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "2.0.0",
  "publisher": "myway",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lx544690189/SQLite-Tool.git"
  },
  "homepage": "https://github.com/lx544690189/SQLite-Tool#readme",
  "bugs": {
    "url": "https://github.com/lx544690189/SQLite-Tool/issues"
  },
  "keywords": [
    "sqlite",
    "database",
    "db",
    "sql",
    "viewer",
    "editor",
    "visualization"
  ],
  "galleryBanner": {
    "color": "#1F6FEB",
    "theme": "dark"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "sqliteTool.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "zh-CN",
            "en",
            "fr",
            "ja",
            "ko"
          ],
          "enumItemLabels": [
            "%configuration.language.auto%",
            "%configuration.language.zhCN%",
            "%configuration.language.en%",
            "%configuration.language.fr%",
            "%configuration.language.ja%",
            "%configuration.language.ko%"
          ],
          "description": "%configuration.language.description%"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "sqliteTool.editor",
        "displayName": "%editor.displayName%",
        "selector": [
          { "filenamePattern": "*.db" },
          { "filenamePattern": "*.sqlite" },
          { "filenamePattern": "*.sqlite3" }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "dev:webview": "vite --config webview/vite.config.ts",
    "build:webview": "vite build --config webview/vite.config.ts",
    "build:ext": "node esbuild.js",
    "build": "npm run build:webview && npm run build:ext",
    "watch:webview": "vite build --watch --config webview/vite.config.ts",
    "watch:ext": "node esbuild.js --watch",
    "sample:db": "node scripts/make-sample-db.cjs",
    "package": "npm run build && vsce package"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.0.3",
    "@ant-design/icons": "^6.1.0",
    "@monaco-editor/react": "^4.7.0",
    "antd": "^6.2.2",
    "dayjs": "^1.11.19",
    "lodash-es": "^4.17.23",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sql-formatter": "^15.7.0",
    "sql.js": "1.13.0",
    "uuid": "^13.0.0",
    "valtio": "^2.3.0"
  },
  "overrides": {
    "dompurify": "3.4.10"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild": "^0.28.1",
    "less": "^4.5.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.16"
  }
}
